@startuml
skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #FBC02D
skinparam wrapWidth 200

|Оператор (Сотрудник теплицы)|
start
:Подготовка оборудования и запуск контроллера робота;
:Запуск главного приложения (ПП ОСК v1.0);
:Выбор источника видеосигнала (Фото, Видео, Камера, RTSP);
:Настройка порога уверенности (Confidence);

|Проектируемый программный продукт (ПП ОСК v1.0)|

:Инициализация модели YOLO Pose и видеопотока;

repeat
    :Захват и чтение кадра;
    :Анализ кадра нейросетью;
    if (Найдена ли спелая ягода (ripe)?) then (Да)
        if (Уверенность точки среза > 0.6?) then (Да)
            :Формирование JSON-пакета с координатами среза;
            :Отправка команды по протоколу UDP;
            
            |Робот-манипулятор (Аппаратная часть)|
            :Прием пакета на порту 5005;
            :Движение манипулятора к координатам X, Y;
            :Осуществление физического среза ягоды;
        else (Нет)
            |Проектируемый программный продукт (ПП ОСК v1.0)|
            :Пропуск объекта (недостаточная точность);
        endif
    else (Нет)
        |Проектируемый программный продукт (ПП ОСК v1.0)|
        :Пропуск кадра (отсутствуют объекты или неспелые);
    endif
    
    |Проектируемый программный продукт (ПП ОСК v1.0)|
    :Отрисовка разметки на кадре (Bbox, точки, линии);
    :Вывод видео потока и обновление статистики в интерфейсе;
    
|Оператор (Сотрудник теплицы)|
repeat while (Требуется завершить работу?) is (Нет)
->Да;
:Нажатие кнопки "ОСТАНОВИТЬ";

|Проектируемый программный продукт (ПП ОСК v1.0)|
:Остановка чтения потоков и освобождение ресурсов;
stop
@enduml